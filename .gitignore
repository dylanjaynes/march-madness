# Environment
.env
.env.*

# Data (raw/processed not committed — re-ingested at runtime)
# data/db/ ← committed so Streamlit Cloud has training data on cold start
data/db/*.db-shm
data/db/*.db-wal
data/raw/
data/processed/

# Trained models are committed so Streamlit Cloud doesn't rebuild on every boot
# models/*.pkl

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# Claude Code
.claude/

# macOS
.DS_Store
.AppleDouble

# Streamlit
.streamlit/secrets.toml

# VS Code / editors
.vscode/
.idea/
*.swp
*.swo
